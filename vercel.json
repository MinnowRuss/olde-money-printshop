{
  "framework": "nextjs",
  "functions": {
    "src/app/api/upload/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/images/[id]/rotate/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/images/[id]/flip/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/webhooks/stripe/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/admin/print-batches/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/stale-orders",
      "schedule": "0 9 * * 1"
    }
  ]
}
