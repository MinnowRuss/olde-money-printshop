# ============================================================
# Olde Money Printshop — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# Supabase (found in your Supabase project settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (http://localhost:3000 for local dev, https://printing.oldemoney.com for production)
NEXT_PUBLIC_URL=http://localhost:3000

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend email (https://resend.com/api-keys)
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=your-audience-id

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
