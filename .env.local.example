# ============================================================
# Olde Money Printshop — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# Supabase (found in your Supabase project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (http://localhost:3000 for local dev)
NEXT_PUBLIC_URL=http://localhost:3000

# Stripe (Phase 5 — add when starting checkout)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Resend email (Phase 7 — add when starting marketing pages)
# RESEND_API_KEY=re_...
